{
  "name": "@alzahra/ui",
  "version": "0.1.0",
  "private": true,
  "description": "Shared UI component library with Tailwind CSS v4 and design system tokens",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./src/styles.css",
    "./tailwind.config": {
      "import": "./tailwind.config.js",
      "require": "./tailwind.config.js"
    }
  },
  "files": [
    "dist",
    "src/styles.css",
    "tailwind.config.js"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/**/*.ts",
    "test": "echo 'No tests yet'",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@alzahra/config": "workspace:*",
    "@types/react": "^19.2.14",
    "react": "^19.2.5",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  }
}
