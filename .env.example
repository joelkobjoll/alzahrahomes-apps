# ═══════════════════════════════════════════════════════════════════════════════
# Alzahra Homes — Environment Configuration
# Copy to .env and fill in all values before deploying.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Node ───────────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── Domains (used for Traefik routing in docker-compose.yml) ───────────────────
AUTH_DOMAIN=auth.alzahra.local
API_DOMAIN=api.alzahra.local
GUEST_WEB_DOMAIN=alzahra.local
ADMIN_WEB_DOMAIN=admin.alzahra.local
MINIO_DOMAIN=minio.alzahra.local
MINIO_CONSOLE_DOMAIN=console.minio.alzahra.local

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=alzahra
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=alzahra
# Full connection string used by apps
DATABASE_URL=postgresql://alzahra:change-me-strong-password@postgres:5432/alzahra?sslmode=disable

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Secrets ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-jwt-secret-min-32-chars
SESSION_SECRET=change-me-session-secret-min-32-chars

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGIN=https://admin.alzahra.local,https://alzahra.local
CORS_ORIGIN_LIST=https://admin.alzahra.local,https://alzahra.local

# ── External APIs ──────────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=AIza...

# ── S3 / MinIO ─────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password
S3_ENDPOINT=https://minio.alzahra.local
S3_BUCKET=alzahra-uploads
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change-me-minio-password
S3_REGION=us-east-1

# ── SMTP ───────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.xxx
SMTP_FROM=noreply@alzahra.local

# ── Frontend build args ────────────────────────────────────────────────────────
API_URL=https://api.alzahra.local
AUTH_URL=https://auth.alzahra.local
