{
  "name": "@alzahra/testing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./factories": {
      "import": "./dist/factories/index.js",
      "types": "./dist/factories/index.d.ts"
    },
    "./fixtures": {
      "import": "./dist/fixtures/index.js",
      "types": "./dist/fixtures/index.d.ts"
    },
    "./mocks": {
      "import": "./dist/mocks/index.js",
      "types": "./dist/mocks/index.d.ts"
    },
    "./helpers": {
      "import": "./dist/helpers/index.js",
      "types": "./dist/helpers/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@alzahra/db": "workspace:*",
    "@alzahra/types": "workspace:*",
    "@alzahra/validators": "workspace:*"
  },
  "devDependencies": {
    "@alzahra/config": "workspace:*",
    "@faker-js/faker": "^9.0.0",
    "@types/node": "^20.12.0",
    "drizzle-orm": "^0.31.0",
    "hono": "^4.3.0",
    "msw": "^2.3.0",
    "postgres": "^3.4.4",
    "testcontainers": "^10.9.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "zod": "^3.23.0"
  }
}
