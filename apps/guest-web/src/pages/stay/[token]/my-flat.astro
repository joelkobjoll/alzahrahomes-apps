---
import MainLayout from '~/layouts/MainLayout.astro';
import PropertyHeader from '~/components/islands/PropertyHeader';
import WifiCard from '~/components/islands/WifiCard';
import MessageThread from '~/components/islands/MessageThread';
import FeedbackForm from '~/components/islands/FeedbackForm';
import { api } from '~/lib/api';
import type { Property } from '@alzahra/types/domain';

const { token } = Astro.params;

if (!token) {
  return Astro.redirect('/');
}

// Server-side data fetching for property details
let property: Property | null = null;
let error: string | null = null;

try {
  const result = await api.getStay(token);

  if (result.error) {
    if (result.error.status === 401 || result.error.status === 403) {
      return Astro.redirect('/?error=invalid_token');
    }
    throw new Error(result.error.message);
  }

  property = result.data?.property ?? null;
} catch (err) {
  error = err instanceof Error ? err.message : 'Unknown error';
}

const pageTitle = property?.name ? `${property.name} — Your Stay` : 'Your Stay';

// Extract WiFi info from property metadata if available (future-proofing)
const wifiSsid = (property as Record<string, unknown> | null)?.wifiSsid as string | null | undefined;
const wifiPassword = (property as Record<string, unknown> | null)?.wifiPassword as string | null | undefined;
---

<MainLayout title={pageTitle}>
  {error && (
    <div class="px-5 py-8 text-center">
      <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-terracotta-100 text-terracotta-600 mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
      </div>
      <h2 class="text-lg font-semibold text-stone-900 mb-1">Could not load your stay</h2>
      <p class="text-sm text-stone-500 mb-4">{error}</p>
      <a href="/" class="inline-flex items-center justify-center h-10 px-5 rounded-lg bg-primary text-primary-foreground text-sm font-medium">Back to Home</a>
    </div>
  )}

  {!error && property && (
    <div class="flex flex-col">
      <PropertyHeader
        client:load
        name={property.name}
        address={property.address}
        city={property.city}
        country={property.country}
        images={property.images ?? []}
      />

      <section class="px-5 py-5">
        <h2 class="text-xl font-bold text-stone-900 mb-3">Your Flat</h2>
        {property.description && (
          <p class="text-sm text-stone-600 leading-relaxed mb-5">{property.description}</p>
        )}

        <div class="grid grid-cols-2 gap-3 mb-5">
          {property.bedrooms !== null && (
            <div class="flex items-center gap-2.5 p-3 rounded-xl bg-sand-100">
              <svg class="text-terracotta-500 shrink-0" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20v-8a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v8"/><path d="M4 10V6a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v4"/><path d="M12 4v6"/><path d="M2 18h20"/></svg>
              <div>
                <p class="text-xs text-stone-500">Bedrooms</p>
                <p class="text-sm font-semibold text-stone-900">{property.bedrooms}</p>
              </div>
            </div>
          )}
          {property.bathrooms && (
            <div class="flex items-center gap-2.5 p-3 rounded-xl bg-sand-100">
              <svg class="text-terracotta-500 shrink-0" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21h6"/><path d="M12 21v-5"/><path d="M12 11V3"/><path d="M15 11V3"/><path d="M9 11V3"/><path d="M5 11h14"/></svg>
              <div>
                <p class="text-xs text-stone-500">Bathrooms</p>
                <p class="text-sm font-semibold text-stone-900">{property.bathrooms}</p>
              </div>
            </div>
          )}
          {property.maxGuests !== null && (
            <div class="flex items-center gap-2.5 p-3 rounded-xl bg-sand-100">
              <svg class="text-terracotta-500 shrink-0" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              <div>
                <p class="text-xs text-stone-500">Max Guests</p>
                <p class="text-sm font-semibold text-stone-900">{property.maxGuests}</p>
              </div>
            </div>
          )}
        </div>

        <WifiCard
          client:load
          ssid={wifiSsid ?? undefined}
          password={wifiPassword ?? undefined}
        />
      </section>

      <section class="px-5 py-5 border-t border-border">
        <h2 class="text-xl font-bold text-stone-900 mb-3">House Rules</h2>
        <ul class="space-y-2.5">
          <li class="flex items-start gap-3 text-sm text-stone-600">
            <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-olive-100 text-olive-600 shrink-0 mt-0.5 text-xs font-bold">1</span>
            Check-in from 15:00, check-out by 11:00
          </li>
          <li class="flex items-start gap-3 text-sm text-stone-600">
            <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-olive-100 text-olive-600 shrink-0 mt-0.5 text-xs font-bold">2</span>
            No smoking inside the property
          </li>
          <li class="flex items-start gap-3 text-sm text-stone-600">
            <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-olive-100 text-olive-600 shrink-0 mt-0.5 text-xs font-bold">3</span>
            Quiet hours: 22:00 — 08:00
          </li>
          <li class="flex items-start gap-3 text-sm text-stone-600">
            <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-olive-100 text-olive-600 shrink-0 mt-0.5 text-xs font-bold">4</span>
            Please lock doors and windows when leaving
          </li>
        </ul>
      </section>

      <section class="px-5 py-5 border-t border-border">
        <h2 class="text-xl font-bold text-stone-900 mb-3">Message Your Host</h2>
        <MessageThread client:load token={token} />
      </section>

      <section class="px-5 py-5 border-t border-border">
        <h2 class="text-xl font-bold text-stone-900 mb-3">How Was Your Stay?</h2>
        <FeedbackForm client:load token={token} />
      </section>
    </div>
  )}
</MainLayout>
